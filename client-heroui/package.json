{
  "name": "chat-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=24.18.0"
  },
  "scripts": {
    "dev": "vite",
    "test": "vitest run",
    "check:i18n": "node scripts/check-i18n-keys.mjs",
    "translate:i18n": "node scripts/translate-i18n.mjs --apply",
    "translate:i18n:dry": "node scripts/translate-i18n.mjs --dry-run",
    "build": "npm run check:i18n && tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "test:e2e": "playwright test",
    "test:e2e:postgres": "E2E_SERVER_PORT=${E2E_SERVER_PORT:-3322} E2E_CLIENT_PORT=${E2E_CLIENT_PORT:-3321} playwright test --config=playwright.postgres.config.ts",
    "test:e2e:headed": "playwright test --headed",
    "preview": "vite preview"
  },
  "dependencies": {
    "@a2ui/markdown-it": "^0.0.3",
    "@a2ui/react": "^0.9.1",
    "@a2ui/web_core": "^0.9.2",
    "@heroicons/react": "^2.2.0",
    "@heroui/react": "2.7.5",
    "@heroui/use-theme": "2.1.6",
    "@iconify/react": "latest",
    "@pierre/diffs": "^1.3.0-beta.5",
    "@pierre/trees": "^1.0.0-beta.4",
    "@tabler/icons-react": "^3.31.0",
    "@tailwindcss/typography": "^0.5.16",
    "@types/katex": "^0.16.7",
    "@types/react-modal": "^3.16.3",
    "@types/socket.io-client": "^1.4.36",
    "@types/uuid": "^10.0.0",
    "browser-image-compression": "^2.0.2",
    "framer-motion": "^11.18.2",
    "heroicons": "^2.2.0",
    "highlight.js": "^11.11.1",
    "i18next": "^24.2.3",
    "i18next-browser-languagedetector": "^8.0.4",
    "katex": "^0.16.21",
    "lucide-react": "^0.564.0",
    "markdown-to-jsx": "^7.7.4",
    "mermaid": "^10.9.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.4.1",
    "react-markdown": "^9.1.0",
    "react-modal": "^3.16.3",
    "react-resizable-panels": "^3.0.1",
    "react-router-dom": "^6.30.0",
    "react-syntax-highlighter": "^15.6.1",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "rehype-sanitize": "^6.0.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "socket.io-client": "^4.8.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.10",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/react-router-dom": "^5.3.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "10.4.20",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "jsdom": "^26.1.0",
    "postcss": "8.4.49",
    "tailwindcss": "3.4.17",
    "typescript": "5.7.3",
    "vite": "^6.0.11",
    "vitest": "^4.1.5"
  }
}
