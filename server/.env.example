# 服务端监听端口
PORT=3012

# 客户端地址（用于 CORS 检查）
CLIENT_URL=http://localhost:3011
NODE_ENV=production

# Redis 配置
REDIS_URL=redis://localhost:6379

# AI 模型配置
AI_MODEL=deepseek-v4-pro
AI_MODEL_OPTIONS=deepseek-v4-pro,gpt-5.5,claude-sonnet-4.6,claude-opus-4.7,kimi-k2.6,glm-5.1,minimax-m2.7

# OpenRouter 配置（用于 Kimi、GLM、MiniMax、Grok、Gemini 等模型）
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY
OPENROUTER_HTTP_REFERER=http://localhost:5173
OPENROUTER_APP_NAME=Message System

# DeepSeek 官方 API（用于 DeepSeek V4 Pro，支持 prompt caching）
DEEPSEEK_API_KEY=YOUR_DEEPSEEK_API_KEY

# Anthropic 官方 API（用于 Claude Sonnet 4.6 / Opus 4.7，支持 prompt caching）
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY
